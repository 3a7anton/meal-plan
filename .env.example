# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Public URL for your Supabase project
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose in browser)
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key (NEVER expose this in browser - only for serverless functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Allowed CORS origins (comma-separated)
# Format: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Node environment (development, production, test)
NODE_ENV=development

# Rate Limiting Configuration
# Auth endpoints: max attempts per window (default: 5 per 15 minutes)
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5

# General API endpoints: max requests per window (default: 100 per 15 minutes)
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100

# Sensitive operations: max requests per window (default: 10 per minute)
RATE_LIMIT_SENSITIVE_WINDOW_MS=60000
RATE_LIMIT_SENSITIVE_MAX=10

# =============================================================================
# APP SETTINGS
# =============================================================================

# Maximum number of approved/activated user accounts allowed (0 = unlimited)
VITE_MAX_APPROVED_USERS=50

# =============================================================================
# SSLCOMMERZ PAYMENT GATEWAY (Student Feature)
# =============================================================================

# SSLCommerz store credentials — get from https://developer.sslcommerz.com/
# Use sandbox credentials for development/testing
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password

# Set to 'true' only in production with a live SSLCommerz account
# 'false' uses the sandbox gateway (https://sandbox.sslcommerz.com)
SSLCOMMERZ_IS_LIVE=false

# =============================================================================
# APP URL
# =============================================================================

# Public-facing URL of this deployment — used for SSLCommerz success/fail/cancel
# and IPN callback URLs. No trailing slash.
# Local:       http://localhost:5173
# Production:  https://meal-plan-psx04r7cq-abu-ahad-antons-projects.vercel.app
VITE_APP_URL=https://meal-plan-psx04r7cq-abu-ahad-antons-projects.vercel.app

# =============================================================================
# VERCEL DEPLOYMENT REMINDER
# =============================================================================
#
# The following variables MUST be added in the Vercel dashboard
# (Project → Settings → Environment Variables) before deploying:
#
#   VITE_SUPABASE_URL             (all environments)
#   VITE_SUPABASE_ANON_KEY        (all environments)
#   SUPABASE_SERVICE_ROLE_KEY     (all environments — server-only)
#   SSLCOMMERZ_STORE_ID           (all environments — server-only)
#   SSLCOMMERZ_STORE_PASSWORD     (all environments — server-only)
#   SSLCOMMERZ_IS_LIVE            (production = true, preview/dev = false)
#   VITE_APP_URL                  (set per environment)
#   ALLOWED_ORIGINS               (production domain)
#
# Variables prefixed with VITE_ are bundled into the client build.
# All other variables are only available in serverless functions (Node.js).
# NEVER expose SUPABASE_SERVICE_ROLE_KEY or SSLCOMMERZ_STORE_PASSWORD
# as VITE_ variables.
